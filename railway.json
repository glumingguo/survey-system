{
  "$schema": "https://railway.app/railway.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJson": {
      "src": "./server",
      "nodejs": "22"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "sleep": true,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
